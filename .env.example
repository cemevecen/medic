# Google Gemini API Anahtarı
# https://aistudio.google.com/app/apikey adresinden alın
GEMINI_API_KEY=your_gemini_api_key_here

# Groq API Anahtarı (LLaVA Vision + Llama-3)
# https://console.groq.com/keys adresinden alın
GROQ_API_KEY=your_groq_api_key_here

# Hugging Face API Anahtarı (opsiyonel, embedding modeli için)
# https://huggingface.co/settings/tokens adresinden alın
HF_API_KEY=your_huggingface_api_key_here
