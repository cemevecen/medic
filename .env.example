# Google Gemini API Anahtarı
# https://aistudio.google.com/app/apikey adresinden alın
GEMINI_API_KEY=your_gemini_api_key_here
# Opsiyonel: gemini-2.5-flash, gemini-1.5-flash, … (boşsa gemini_models zinciri kullanılır)
# GEMINI_MODEL=

# Groq API Anahtarı (LLaVA Vision + Llama-3)
# https://console.groq.com/keys adresinden alın
GROQ_API_KEY=your_groq_api_key_here
# Safety Auditor Groq modelleri (virgülle); 429/TPD olunca sırayla denenir.
# GROQ_SAFETY_MODEL_PRIORITY=llama-3.3-70b-versatile,llama-3.1-8b-instant,llama-3.1-70b-versatile

# Hugging Face API Anahtarı (opsiyonel, embedding modeli için)
# https://huggingface.co/settings/tokens adresinden alın
HF_API_KEY=your_huggingface_api_key_here
